---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const defaultTitle = "Frankie Ramirez - Staff Software Engineer & Frontend Architect";
const defaultDescription =
  "Frankie Ramirez leads frontend architecture, design-system, and product workflow work for teams building coherent, accessible, AI-assisted interfaces.";
const defaultImage = "/og.png";
const {
  title = defaultTitle,
  description = defaultDescription,
  image = defaultImage,
  canonical,
} = Astro.props;

const siteUrl = "https://frankieramirez.com";
const siteHref = Astro.site?.href ?? siteUrl;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteHref).href;
const ogImage = new URL(image, siteHref).href;
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Frankie Ramirez",
  jobTitle: "Staff Software Engineer",
  description:
    "Staff Software Engineer and frontend architect leading design systems, product workflow architecture, and AI-assisted engineering practice",
  url: siteHref,
  sameAs: [
    "https://linkedin.com/in/frankieramirez",
    "https://x.com/frankiedevs",
    "https://github.com/frankieramirez",
    "https://bsky.app/profile/frankieramirez.bsky.social",
    "https://mastodon.social/@frankieramirez",
  ],
  address: {
    "@type": "PostalAddress",
    addressRegion: "New Jersey",
    addressCountry: "US",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content="Frankie Ramirez" />
    <meta name="theme-color" content="#FAFAF8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#080807" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Frankie Ramirez" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@frankiedevs" />

    <link rel="dns-prefetch" href="https://linkedin.com" />
    <link rel="dns-prefetch" href="https://x.com" />
    <link rel="dns-prefetch" href="https://github.com" />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <slot />
    <Footer />

    <script>
      import { initPointerSpotlights } from "@/scripts/pointer-spotlight";

      initPointerSpotlights();
      document.addEventListener("astro:page-load", initPointerSpotlights);
    </script>
  </body>
</html>
