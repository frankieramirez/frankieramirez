---

<section class="section ledger-section" id="work" aria-labelledby="work-title">
  <div class="wrap section-grid">
    <div class="section-label">Work</div>
    <div class="section-body">
      <div class="section-heading">
        <h2 id="work-title">A Ledger of Shipped and Redacted Work.</h2>
        <p>
          Public links first. Confidential work stays specific enough to judge the thinking without inventing numbers or naming companies.
        </p>
      </div>

      <div class="ledger" role="list">
        {rows.map((row) => (
          <article class="ledger-row spotlight-panel" role="listitem" data-spotlight>
            <div class="ledger-status">{row.status}</div>
            <div class="ledger-main">
              <h3>{row.title}</h3>
              <p>{row.summary}</p>
            </div>
            <div class="ledger-evidence">
              <span>Evidence</span>
              <p>{row.evidence}</p>
            </div>
            <div class="ledger-links" aria-label={`${row.title} links`}>
              {row.links.length > 0 ? (
                row.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noopener">
                    {link.label}
                  </a>
                ))
              ) : (
                <span>Redacted</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
