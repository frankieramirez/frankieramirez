---
const cells = [
  {
    n: "/ 01",
    title: "Design systems that hold their shape",
    body: "Token-driven, accessible, documented. I build the primitives, the contribution model, and the governance that keeps a system from forking itself at 18 months.",
    tags: ["tokens", "a11y", "theming", "docs"],
  },
  {
    n: "/ 02",
    title: "Product architecture at scale",
    body: "Module boundaries, routing strategies, data layers, build pipelines. Turning a pile of features into an app that engineers can actually reason about.",
    tags: ["react", "typescript", "rsc", "monorepo"],
  },
  {
    n: "/ 03",
    title: "AI-forward engineering practice",
    body: "Wiring LLMs into the seams — agentic review loops, evals, generative UI patterns, and internal tools that compress the work around the work.",
    tags: ["agents", "evals", "gen-ui", "tooling"],
  },
  {
    n: "/ 04",
    title: "Interfaces that feel deliberate",
    body: "Motion that earns its place, type set with attention, interaction states that acknowledge the user. The unglamorous craft that separates a product from a demo.",
    tags: ["motion", "type", "layout", "detail"],
  },
  {
    n: "/ 05",
    title: "The refactor as deliverable",
    body: "Shipping the invisible work — migrations, decomposition, performance — without freezing the team. Believing that codebase health is a product feature.",
    tags: ["migrations", "perf", "dx"],
  },
  {
    n: "/ 06",
    title: "Mentorship & code review",
    body: "The multiplier role: making the people around me better engineers. Reviewing with care, writing prose that outlives the Slack thread, picking battles that teach.",
    tags: ["review", "writing", "mentoring"],
  },
];

const stack = [
  "TypeScript", "React", "Next.js", "Remix", "Tailwind", "Radix", "tRPC",
  "GraphQL", "Vite", "Turborepo", "Storybook", "Playwright", "Node", "Postgres",
  "Redis", "OpenAI", "Anthropic", "Figma",
];
---

<section class="section" id="focus">
  <div class="wrap">
    <div class="section-head">
      <div>
        <div class="section-num">
          <span class="folio">ii.</span>
          <span class="rule"></span>§ 02 — Focus
        </div>
      </div>
      <h2 class="section-title">What I do <em>well.</em></h2>
    </div>

    <div class="focus-grid">
      {cells.map((c) => (
        <div class="focus-cell">
          <div class="focus-num">{c.n}</div>
          <h3 class="focus-title">{c.title}</h3>
          <p class="focus-body">{c.body}</p>
          <div class="focus-tags">
            {c.tags.map((t) => <span class="tag-chip">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

    <div class="ticker-wrap">
      <div class="ticker">
        {stack.map((s) => <span>{s}</span>)}
        {stack.map((s) => <span>{s}</span>)}
      </div>
    </div>
  </div>
</section>
