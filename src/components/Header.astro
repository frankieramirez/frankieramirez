---
const navLinks = [
  { href: "#work", label: "Work" },
  { href: "#judgment", label: "Judgment" },
  { href: "#contact", label: "Contact" },
];
---

<header class="site-header">
  <div class="wrap header-inner">
    <a class="brand" href="/" aria-label="Frankie Ramirez home">
      frankie<span class="brand-sep">/</span>ramirez
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <a class="header-contact" href="mailto:hello@frankieramirez.com">Email</a>
  </div>
</header>
