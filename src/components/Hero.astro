<!-- Hero A — Editorial -->
<section class="hero">
  <div class="hero-a wrap">
    <div class="eyebrow">
      <span class="bar"></span>
      <span>Portfolio · 2026</span>
      <span>—</span>
      <span>Philadelphia Metro</span>
    </div>

    <h1 class="display">
      Frontend <em>architect</em><br />
      building <span class="accent-ink">deliberate</span><br />
      interfaces.
    </h1>

    <p class="hero-lede">
      I'm <b>Frankie Ramirez</b> — a staff-level frontend engineer with <b>14 years</b> of shipping scalable web applications across CRM, proptech and SaaS. I design systems that survive contact with real teams, and interfaces that feel considered at every pixel.
    </p>

    <div class="hero-meta">
      <div class="meta-item">
        <div class="meta-label">Role</div>
        <div class="meta-value">Staff Software Engineer</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Specialty</div>
        <div class="meta-value">Design systems · architecture</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Experience</div>
        <div class="meta-value">14+ years</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Availability</div>
        <div class="meta-value">Selective · Q3 2026</div>
      </div>
    </div>
  </div>
</section>

<!-- Hero B — Terminal -->
<section class="hero hero-b">
  <div class="cursor-grid" id="cursor-grid"></div>
  <div class="wrap">
    <div class="terminal-frame">
      <div class="prompt-row">
        <span class="arrow">→</span>
        <span>~/frankieramirez</span>
        <span style="color: var(--accent)">·</span>
        <span>main</span>
        <span style="opacity:.4">—</span>
        <span>whoami</span>
      </div>

      <h1 class="name-b">
        Frankie<br />Ramirez<span class="cursor"></span>
      </h1>

      <div class="role-b">
        <span class="tag">&lt;role&gt;</span>
        Staff Software Engineer &amp; Frontend Architect
        <span class="tag">&lt;/role&gt;</span>
      </div>

      <p class="lede-b">
        I architect design systems and ship production frontends at scale. 14 years between CRM, proptech and SaaS — currently exploring AI-forward patterns in product engineering.
      </p>

      <div class="metrics">
        <div class="metric">
          <div class="metric-val">14<sub>yrs</sub></div>
          <div class="metric-label">Shipping</div>
        </div>
        <div class="metric">
          <div class="metric-val">6</div>
          <div class="metric-label">Design systems</div>
        </div>
        <div class="metric">
          <div class="metric-val">3</div>
          <div class="metric-label">Verticals</div>
        </div>
        <div class="metric">
          <div class="metric-val">∞</div>
          <div class="metric-label">Pull requests</div>
        </div>
      </div>
    </div>
  </div>
</section>
