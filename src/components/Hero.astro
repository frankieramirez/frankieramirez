---
const operatingModel = [
  {
    label: "Primitive Layer",
    detail: "Tokens, states, semantics, accessibility, type",
  },
  {
    label: "Workflow Layer",
    detail: "Routes, data contracts, review flows, eval tasks",
  },
  {
    label: "Adoption Layer",
    detail: "Docs, contribution paths, PR review, release guardrails",
  },
];

const meta = [
  { label: "Experience", value: "14+ years" },
  { label: "Focus", value: "Frontend architecture" },
  { label: "Edge", value: "AI-assisted engineering" },
];
---

<section class="hero">
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="hero-kicker">Staff Software Engineer · Frontend Architecture · Design Systems</p>
      <h1>I make complex product interfaces coherent at team scale.</h1>
      <p class="hero-lede">
        I lead frontend architecture, design systems, and product workflow design for teams that need complex interfaces to stay fast, accessible, and consistent as the organization grows.
      </p>
    </div>

    <aside class="hero-aside" aria-label="Working model">
      <div class="operating-model" data-spotlight>
        <div class="operating-model-inner">
          <div class="operating-model-head">
            <span>Working Model</span>
            <span class="operating-model-version">v1</span>
          </div>
          {operatingModel.map((row) => (
            <div class="operating-model-row">
              <h3>{row.label}</h3>
              <p>{row.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-meta">
        {meta.map((item) => (
          <div class="hero-meta-item">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>
