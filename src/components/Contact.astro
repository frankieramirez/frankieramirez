---
const primaryLinks = [
  { label: "Email", value: "hello@frankieramirez.com", href: "mailto:hello@frankieramirez.com" },
  { label: "GitHub", value: "@frankieramirez", href: "https://github.com/frankieramirez" },
  { label: "Resume", value: "PDF", href: "/resume.pdf" },
];
---

<section class="section contact-section" id="contact" aria-labelledby="contact-title">
  <div class="wrap section-grid">
    <div class="section-label">Contact</div>
    <div class="section-body">
      <div class="section-heading">
        <h2 id="contact-title">Best Fit: Staff Software Engineer, Frontend Architecture, Design Systems.</h2>
        <p>
          I am most useful where product teams need interface quality, system governance, product architecture, and AI-assisted engineering practice to move together.
        </p>
      </div>

      <div class="contact-links" aria-label="Primary contact links">
        {primaryLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener" : undefined}
          >
            <span>{link.label}</span>
            <strong>{link.value}</strong>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
